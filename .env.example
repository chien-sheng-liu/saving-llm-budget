# Reference: environment variables used by saving-llm-budget.
# This tool reads directly from your shell environment — it does NOT load .env files.
#
# Add the lines you need to ~/.zshrc or ~/.bashrc, then run: source ~/.zshrc
#
# Only needed if you chose "API Key" mode during `slb init`.
# If you chose "Local CLI" mode for a provider, its key is not required.

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Optional override for where CLI config is stored.
# SAVING_LLM_BUDGET_CONFIG_DIR=/path/to/custom/.saving-llm-budget