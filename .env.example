# API keys used by saving-llm-budget. Keep these secrets out of version control.
# Copy this file to .env and fill in real values. Never commit .env to git.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Optional override for where CLI config is stored.
# SAVING_LLM_BUDGET_CONFIG_DIR=/path/to/custom/.saving-llm-budget